Dialogue: 0,0:00:03.79,0:00:06.26,Default,,0,0,0,,Selamat pagi, Nona-Nona!\NBagaimana hari kalian?
Dialogue: 0,0:00:06.26,0:00:08.19,Default,,0,0,0,,Hariku luar biasa, tentu saja!
Dialogue: 0,0:00:08.19,0:00:09.86,Default,,0,0,0,,Selamat pagi!
Dialogue: 0,0:00:09.86,0:00:11.10,Default,,0,0,0,,Pagi.
Dialogue: 0,0:00:11.70,0:00:13.28,Default,,0,0,0,,Kau benar-benar lebih ceria.
Dialogue: 0,0:00:16.49,0:00:18.70,Default,,0,0,0,,Apa ini? Apakah aku tidak mendapat salam?
Dialogue: 0,0:00:19.04,0:00:20.66,Default,,0,0,0,,Aku mengumumkan kehadiranku.
Dialogue: 0,0:00:22.54,0:00:23.53,Default,,0,0,0,,Baiklah.
Dialogue: 0,0:00:23.53,0:00:25.46,Default,,0,0,0,,Kita harus bersiap untuk siaran pagi.
Dialogue: 0,0:00:25.46,0:00:27.49,Default,,0,0,0,,Adapun revisi naskahnya...
Dialogue: 0,0:00:27.49,0:00:29.06,Default,,0,0,0,,Tanyakan itu kepadaku, Bodoh!
Dialogue: 0,0:00:29.06,0:00:30.38,Default,,0,0,0,,Untuk apa itu?!
Dialogue: 0,0:00:30.38,0:00:31.68,Default,,0,0,0,,Jangan abaikan aku!
Dialogue: 0,0:00:31.68,0:00:33.97,Default,,0,0,0,,Seharusnya kau curiga\Nada yang tidak beres dan bertanya!
Dialogue: 0,0:00:33.97,0:00:36.51,Default,,0,0,0,,Benar. Aku minta maaf.
Dialogue: 0,0:00:36.51,0:00:37.64,Default,,0,0,0,,Apakah sesuatu terjadi?
Dialogue: 0,0:00:40.24,0:00:41.09,Default,,0,0,0,,Aku tidak akan bilang.
Dialogue: 0,0:00:41.09,0:00:42.06,Default,,0,0,0,,Kenapa dia?!
Dialogue: 0,0:00:42.06,0:00:44.22,Default,,0,0,0,,Pembicaraannya tidak jelas!
Dialogue: 0,0:00:44.59,0:00:47.73,Default,,0,0,0,,Kau berbicara atau tidak? Yang mana?!
Dialogue: 0,0:00:48.10,0:00:49.70,Default,,0,0,0,,Oh, diamlah, kau!
Dialogue: 0,0:00:49.70,0:00:51.89,Default,,0,0,0,,Ada sesuatu yang harus kuurus.\NSampai nanti!
Dialogue: 0,0:00:56.64,0:00:58.10,Default,,0,0,0,,Kenapa dia?
Dialogue: 0,0:00:58.10,0:01:00.22,Default,,0,0,0,,Itu ejekan yang menggemaskan.
Dialogue: 0,0:01:00.22,0:01:04.48,Default,,0,0,0,,Nene–chan telah menjadi pemukul pengganti\Nuntuk klub teater selama seminggu.
Dialogue: 0,0:01:04.48,0:01:05.60,Default,,0,0,0,,Klub teater?
Dialogue: 0,0:01:05.60,0:01:07.57,Default,,0,0,0,,Sepertinya situasinya tidak berjalan baik.
Dialogue: 0,0:01:07.57,0:01:10.79,Default,,0,0,0,,Dia setuju\Nkarena itu bisa membantu aktingnya.
Dialogue: 0,0:01:12.13,0:01:14.96,Default,,0,0,0,,Aku selalu mengira dia pandai bergaul\Ndengan kelompok mana pun.
Dialogue: 0,0:01:14.96,0:01:19.94,Default,,0,0,0,,Tidak juga. Dia mengabaikan\Norang-orang yang tidak dekat dengannya.
Dialogue: 0,0:01:19.94,0:01:21.59,Default,,0,0,0,,Namun, dia ceria di kelas.
Dialogue: 0,0:01:21.59,0:01:24.42,Default,,0,0,0,,Nene hanya menyukai\Norang-orang yang menyukainya.
Dialogue: 0,0:01:24.42,0:01:25.70,Default,,0,0,0,,Benarkah?
Dialogue: 0,0:01:26.55,0:01:28.80,Default,,0,0,0,,Aku benci orang yang membenciku!
Dialogue: 0,0:01:29.15,0:01:30.60,Default,,0,0,0,,Ya, aku bisa membayangkan itu.
Dialogue: 0,0:01:30.60,0:01:33.55,Default,,0,0,0,,Menurutmu, kau bisa membantunya,\NYamabuki–kun?
Dialogue: 0,0:01:33.55,0:01:38.06,Default,,0,0,0,,Tidak jika aku tidak tahu\Napa akar masalahnya.
Dialogue: 0,0:01:38.45,0:01:40.69,Default,,0,0,0,,Bukki, kumohon?
Dialogue: 0,0:01:42.63,0:01:43.90,Default,,0,0,0,,Jangan konyol.
Dialogue: 0,0:01:43.90,0:01:48.06,Default,,0,0,0,,Bagaimana orang berharap menyelesaikan\Nmasalah yang tidak dibicarakannya?
Dialogue: 0,0:01:48.06,0:01:52.02,Default,,0,0,0,,Selain itu, akting suara dan akting adalah\Nkeahlian berbeda meski terlihat sama.
Dialogue: 0,0:01:52.02,0:01:55.03,Default,,0,0,0,,Nasihat yang tak dipertimbangkan baik-baik\Nhanya menjadi kontraproduktif.
Dialogue: 0,0:01:55.34,0:01:59.29,Default,,0,0,0,,Sayangnya saat ini tidak ada seorang pun\Nyang mampu membantunya.
Dialogue: 0,0:02:02.44,0:02:05.50,Default,,0,0,0,,Selain {\i1}aku!{\i0}
Dialogue: 0,0:02:05.50,0:02:06.98,Default,,0,0,0,,Terlalu mudah!
Dialogue: 0,0:02:06.98,0:02:10.17,Default,,0,0,0,,Dengan sedikit sanjungan saja, dia hancur!
Dialogue: 0,0:02:10.17,0:02:11.44,Default,,0,0,0,,"Klub Teater"
Dialogue: 0,0:02:11.44,0:02:12.17,Default,,0,0,0,,Ahhh!
Dialogue: 0,0:02:12.17,0:02:15.84,Default,,0,0,0,,Maaf atas perbuatanku yang menyedihkan!
Dialogue: 0,0:02:15.89,0:02:20.97,Default,,0,0,0,,Aku tidak bisa mencintaimu\Nmeski kita dekat!
Dialogue: 0,0:02:21.28,0:02:24.24,Default,,0,0,0,,Oizumi–san benar-benar\Nmencurahkan jiwanya.
Dialogue: 0,0:02:24.24,0:02:28.74,Default,,0,0,0,,Mimpinya adalah menjadi aktris\Ndan menikah hingga menjadi terkenal.
Dialogue: 0,0:02:28.74,0:02:31.73,Default,,0,0,0,,Bukankah mimpinya menikah dengan orang\Nyang punya uang dan kekuasaan besar?
Dialogue: 0,0:02:31.73,0:02:39.00,Default,,0,0,0,,Kumohon! Jika kau mau memaafkanku,\Napi cinta masih menyala!
Dialogue: 0,0:02:39.00,0:02:42.49,Default,,0,0,0,,Bisakah kau mengatakan\Nbahwa kau mencintaiku sekali lagi?!
Dialogue: 0,0:02:42.49,0:02:43.70,Default,,0,0,0,,Ya, aku mencintaimu.
Dialogue: 0,0:02:43.70,0:02:45.08,Default,,0,0,0,,Apa?!
Dialogue: 0,0:02:45.08,0:02:46.28,Default,,0,0,0,,Oizumi–san?!
Dialogue: 0,0:02:46.77,0:02:49.02,Default,,0,0,0,,Cut, cut! Berhenti merekam.
Dialogue: 0,0:02:49.02,0:02:50.26,Default,,0,0,0,,Kami tidak pernah merekam.
Dialogue: 0,0:02:50.26,0:02:51.50,Default,,0,0,0,,Himekawa–san!
Dialogue: 0,0:02:51.76,0:02:53.10,Default,,0,0,0,,Berapa kali kita harus melakukan ini?
Dialogue: 0,0:02:53.10,0:02:55.13,Default,,0,0,0,,Apakah kau benar-benar membaca naskahnya?!
Dialogue: 0,0:02:55.85,0:02:57.42,Default,,0,0,0,,Tapi aku sudah membacanya?
Dialogue: 0,0:02:57.42,0:02:59.30,Default,,0,0,0,,Kau bisa saja membodohiku!
Dialogue: 0,0:03:02.05,0:03:04.40,Default,,0,0,0,,Ke mana perginya semangatnya?
Dialogue: 0,0:03:04.40,0:03:05.13,Default,,0,0,0,,Dengar!
Dialogue: 0,0:03:05.42,0:03:07.57,Default,,0,0,0,,Dalam adegan ini, perasaan mereka sama!
Dialogue: 0,0:03:07.57,0:03:09.96,Default,,0,0,0,,Namun, si bodoh membiarkan dirinya\Ndirayu oleh wanita lain
Dialogue: 0,0:03:09.96,0:03:11.76,Default,,0,0,0,,hanya karena perselisihan kecil.
Dialogue: 0,0:03:11.76,0:03:15.14,Default,,0,0,0,,Sekarang cinta dalam hidupnya melihat\Ndia memohon dengan menyedihkan,
Dialogue: 0,0:03:15.14,0:03:18.56,Default,,0,0,0,,saat dia mencoba mengesampingkan\Nperasaan campur aduknya dan memaafkannya!
Dialogue: 0,0:03:18.84,0:03:21.61,Default,,0,0,0,,Ini adegan yang sangat kompleks,\Ntapi mengharukan!
Dialogue: 0,0:03:21.61,0:03:23.82,Default,,0,0,0,,Namun, dengan aktingmu, itu seperti,
Dialogue: 0,0:03:23.82,0:03:25.69,Default,,0,0,0,,"Ya, aku mencintaimu!"
Dialogue: 0,0:03:25.69,0:03:27.11,Default,,0,0,0,,Dangkal sekali?!
Dialogue: 0,0:03:27.11,0:03:28.18,Default,,0,0,0,,Oizumi–san!
Dialogue: 0,0:03:28.18,0:03:30.28,Default,,0,0,0,,Berhenti meluncurkan dirimu\Nke perlengkapan kita.
Dialogue: 0,0:03:30.28,0:03:33.47,Default,,0,0,0,,Payah! Kau membawakannya tanpa jiwa!
Dialogue: 0,0:03:33.47,0:03:35.38,Default,,0,0,0,,T–Tanpa jiwa?
Dialogue: 0,0:03:35.38,0:03:38.71,Default,,0,0,0,,Aku hanya melakukan sesuai dengan\Nyang kupikir seharusnya dilakukan.
Dialogue: 0,0:03:38.71,0:03:39.76,Default,,0,0,0,,Kau pikir?
Dialogue: 0,0:03:39.76,0:03:42.40,Default,,0,0,0,,Jangan bilang kau {\i1}berpikir{\i0}\Nsaat berakting?!
Dialogue: 0,0:03:42.40,0:03:42.92,Default,,0,0,0,,Hah?
Dialogue: 0,0:03:42.92,0:03:45.05,Default,,0,0,0,,Itu tidak boleh dilakukan dalam berakting.
Dialogue: 0,0:03:45.05,0:03:48.29,Default,,0,0,0,,Apakah kau pernah berpikir\N"Baiklah, keluarkan air mata"
Dialogue: 0,0:03:48.29,0:03:49.75,Default,,0,0,0,,sebelum menangis atau merasa kesal?
Dialogue: 0,0:03:49.75,0:03:53.34,Default,,0,0,0,,Bukankah emosi lahir dari dorongan hati,\Nbukan dari pikiran sadar?
Dialogue: 0,0:03:53.71,0:03:55.26,Default,,0,0,0,,Kau tidak seperti itu?
Dialogue: 0,0:03:55.26,0:03:57.78,Default,,0,0,0,,A–Aku, itu...
Dialogue: 0,0:03:59.23,0:04:00.30,Default,,0,0,0,,Sulit kupercaya.
Dialogue: 0,0:04:00.58,0:04:02.89,Default,,0,0,0,,Kau bahkan tidak punya jawaban untuk itu?
Dialogue: 0,0:04:03.97,0:04:07.14,Default,,0,0,0,,{\i1}Aku mengerti.\NAku pernah mendengar ini sebelumnya.{\i0}
Dialogue: 0,0:04:07.14,0:04:08.94,Default,,0,0,0,,Baiklah, dari awal!
Dialogue: 0,0:04:08.94,0:04:11.80,Default,,0,0,0,,Lakukan dengan benar kali ini,\NHimekawa–san.
Dialogue: 0,0:04:11.80,0:04:12.90,Default,,0,0,0,,Baiklah...
Dialogue: 0,0:04:14.40,0:04:18.15,Default,,0,0,0,,{\i1}Ugh! Sebenarnya apa kesalahanku?!{\i0}
Dialogue: 0,0:04:18.15,0:04:21.14,Default,,0,0,0,,{\i1}Aku menyetujui ini karena berpikir\Naku bisa belajar dari mereka.{\i0}
Dialogue: 0,0:04:21.14,0:04:24.70,Default,,0,0,0,,{\i1}Aku tidak akan pernah setuju\Njika aku tahu aku hanya akan dihina! Bah!{\i0}
Dialogue: 0,0:04:25.04,0:04:27.74,Default,,0,0,0,,{\i1}Aku, berpikir dan berakting? Ya, ya!{\i0}
Dialogue: 0,0:04:27.74,0:04:29.81,Default,,0,0,0,,{\i1}Aku banyak berpikir dalam hal ini!{\i0}
Dialogue: 0,0:04:29.81,0:04:34.04,Default,,0,0,0,,{\i1}Masalahnya, aku tak punya panduan visual,\Ntidak seperti anime dan manga!{\i0}
Dialogue: 0,0:04:34.30,0:04:38.25,Default,,0,0,0,,{\i1}Bahkan sekarang aku mempertimbangkan\Nlangkahku untuk memberi penampilan bagus,{\i0}
Dialogue: 0,0:04:38.25,0:04:40.63,Default,,0,0,0,,{\i1}dan bagaimana cara mengekspresikan\Nemosi yang benar!{\i0}
Dialogue: 0,0:04:41.96,0:04:45.22,Default,,0,0,0,,Bisakah kau mengatakan\Nbahwa kau mencintaiku sekali lagi?!
Dialogue: 0,0:04:45.53,0:04:48.57,Default,,0,0,0,,{\i1}Aku berpikir, berpikir, dan berpikir lagi!{\i0}
Dialogue: 0,0:04:51.45,0:04:54.81,Default,,0,0,0,,Y–Ya, aku mencintaimu.
Dialogue: 0,0:04:56.23,0:04:58.19,Default,,0,0,0,,Toiletnya ada di luar, di sebelah kanan.
Dialogue: 0,0:04:58.19,0:04:59.86,Default,,0,0,0,,A–Aku tidak sedang menahan itu!
Dialogue: 0,0:04:59.86,0:05:02.25,Default,,0,0,0,,Memijat bagian belakang lutut\Nmembantu mengatasi kaki mati rasa.
Dialogue: 0,0:05:02.25,0:05:04.74,Default,,0,0,0,,Ka... Kakiku tidak mati rasa!
Dialogue: 0,0:05:04.74,0:05:08.69,Default,,0,0,0,,{\i1}Aku tidak pernah tahu\Ndia adalah pemalu di luar klub.{\i0}
Dialogue: 0,0:05:09.37,0:05:12.45,Default,,0,0,0,,{\i1}Hari ini cerah lagi.{\i0}
Dialogue: 0,0:05:17.71,0:05:21.31,Default,,0,0,0,,Kita kembali ke kelas.
Dialogue: 0,0:05:29.52,0:05:32.43,Default,,0,0,0,,Apakah hanya perasaanku,\Natau suasana hatinya makin buruk?
Dialogue: 0,0:05:32.43,0:05:34.60,Default,,0,0,0,,Kita harus menenangkannya\Ndengan pengorbanan
Dialogue: 0,0:05:34.60,0:05:35.70,Default,,0,0,0,,atau semuanya akan hancur.
Dialogue: 0,0:05:35.70,0:05:37.84,Default,,0,0,0,,Ugh, dia sangat menyebalkan!
Dialogue: 0,0:05:38.18,0:05:39.90,Default,,0,0,0,,Oizumi itu!
Dialogue: 0,0:05:39.90,0:05:43.10,Default,,0,0,0,,"Jangan berpikir, rasakan?!"\NMemangnya siapa dia, {\i1}Bruce Lee?!{\i0}
Dialogue: 0,0:05:43.10,0:05:44.73,Default,,0,0,0,,Emosi datang dari impuls?!
Dialogue: 0,0:05:44.73,0:05:47.06,Default,,0,0,0,,Dia hanya berbicara omong kosong\Nagar merasa nyaman dengan dirinya sendiri!
Dialogue: 0,0:05:47.06,0:05:49.36,Default,,0,0,0,,Semua ini tidak masuk akal!
Dialogue: 0,0:05:52.30,0:05:55.86,Default,,0,0,0,,{\i1}Nene, kau gadis kecil Ayah yang penurut.{\i0}
Dialogue: 0,0:05:56.46,0:05:58.84,Default,,0,0,0,,{\i1}Benar sekali,\Naku berpikir sebelum berakting!{\i0}
Dialogue: 0,0:05:58.84,0:06:02.99,Default,,0,0,0,,{\i1}Aku selalu memikirkan\Napa yang dia ingin lihat!{\i0}
Dialogue: 0,0:06:09.73,0:06:11.46,Default,,0,0,0,,Yamabuki–kun mengambil risiko!
Dialogue: 0,0:06:14.06,0:06:15.13,Default,,0,0,0,,Kau mau apa?
Dialogue: 0,0:06:15.41,0:06:17.77,Default,,0,0,0,,Aku melihatmu di klub teater kemarin.
Dialogue: 0,0:06:17.77,0:06:18.38,Default,,0,0,0,,Hah?
Dialogue: 0,0:06:18.38,0:06:20.12,Default,,0,0,0,,Aku ingin memberitahumu sesuatu.
Dialogue: 0,0:06:20.12,0:06:20.80,Default,,0,0,0,,Apa itu?
Dialogue: 0,0:06:21.12,0:06:23.88,Default,,0,0,0,,Apakah kau datang untuk menghiburku?
Dialogue: 0,0:06:24.29,0:06:26.32,Default,,0,0,0,,Sudah agak lama aku memikirkan ini.
Dialogue: 0,0:06:27.13,0:06:30.90,Default,,0,0,0,,Apakah pita rambut itu dimaksudkan\Nuntuk membangkitkan kumbang rusa?
Dialogue: 0,0:06:35.35,0:06:37.45,Default,,0,0,0,,Kau datang hanya untuk menanyakan {\i1}itu!?{\i0}
Dialogue: 0,0:06:37.45,0:06:38.81,Default,,0,0,0,,Sialan, kau berengsek!
Dialogue: 0,0:06:38.81,0:06:40.60,Default,,0,0,0,,Apa yang kau pikirkan?!
Dialogue: 0,0:06:42.19,0:06:44.57,Default,,0,0,0,,Itulah, Himekawa, yang kita sebut impuls.
Dialogue: 0,0:06:44.84,0:06:47.83,Default,,0,0,0,,Apakah kau berhati-hati mempertimbangkan\Nlangkahmu sebelum menghajarku?
Dialogue: 0,0:06:47.83,0:06:48.98,Default,,0,0,0,,Diam!
Dialogue: 0,0:06:51.21,0:06:52.32,Default,,0,0,0,,Asal kau tahu...
Dialogue: 0,0:06:52.66,0:06:54.24,Default,,0,0,0,,aku mengusahakan yang terbaik...
Dialogue: 0,0:06:54.24,0:06:56.20,Default,,0,0,0,,Itu dia, Himekawa.
Dialogue: 0,0:06:56.20,0:06:59.06,Default,,0,0,0,,Emosi mentahmu muncul ke permukaan.
Dialogue: 0,0:06:59.06,0:07:00.14,Default,,0,0,0,,Namun...
Dialogue: 0,0:07:05.88,0:07:09.75,Default,,0,0,0,,Aku tidak tahan dipermalukan!
Dialogue: 0,0:07:09.75,0:07:12.21,Default,,0,0,0,,Bagus! Itu penampilan yang luar biasa!
Dialogue: 0,0:07:12.50,0:07:15.43,Default,,0,0,0,,Ikuti nalurimu tanpa berpikir!
Dialogue: 0,0:07:15.43,0:07:17.42,Default,,0,0,0,,Apakah kau merasa frustrasi?\NKalau begitu, balas dendam!
Dialogue: 0,0:07:17.42,0:07:18.78,Default,,0,0,0,,Aku akan memberimu pelatihan khusus!
Dialogue: 0,0:07:18.78,0:07:20.43,Default,,0,0,0,,Aku lebih baik mati!
Dialogue: 0,0:07:20.43,0:07:22.97,Default,,0,0,0,,Bagus! Emosimu terlihat!
Dialogue: 0,0:07:22.97,0:07:25.98,Default,,0,0,0,,"Emosi Berasal Dari Impuls"
Dialogue: 0,0:07:32.77,0:07:34.27,Default,,0,0,0,,"Tune In to the Midnight Heart"
Dialogue: 0,0:07:36.15,0:07:36.98,Default,,0,0,0,,"Shinobu Uzuki"
Dialogue: 0,0:07:37.99,0:07:39.11,Default,,0,0,0,,"Iko Kirino"
Dialogue: 0,0:07:39.86,0:07:40.99,Default,,0,0,0,,"Nene Himekawa"
Dialogue: 0,0:07:41.61,0:07:43.03,Default,,0,0,0,,"Rikka Inohana"
Dialogue: 0,0:07:43.03,0:07:45.41,Default,,0,0,0,,"Tune In to the Midnight Heart"
Dialogue: 0,0:08:18.27,0:08:19.35,Default,,0,0,0,,"Apollo!?"
Dialogue: 0,0:08:53.65,0:08:55.88,Default,,0,0,0,,"Tune In to the Midnight Heart"
Dialogue: 0,0:08:58.78,0:09:01.90,Default,,0,0,0,,Orang sering berbicara\Ntentang "mendalami karakter",
Dialogue: 0,0:09:01.90,0:09:04.39,Default,,0,0,0,,tapi kau tidak bisa melakukannya\Ntanpa pengalaman.
Dialogue: 0,0:09:04.76,0:09:06.64,Default,,0,0,0,,Bagaimanapun,\Nkau bukan aktris profesional.
Dialogue: 0,0:09:07.18,0:09:09.77,Default,,0,0,0,,Jadi, untuk berperan sebagai kekasih\Nyang dihina karena perselingkuhan,
Dialogue: 0,0:09:10.09,0:09:13.51,Default,,0,0,0,,kau harus mengalami diselingkuhi.
Dialogue: 0,0:09:13.51,0:09:15.52,Default,,0,0,0,,Jadi...
Dialogue: 0,0:09:15.52,0:09:17.79,Default,,0,0,0,,Maaf! Maafkan perselingkuhanku!
Dialogue: 0,0:09:17.79,0:09:19.46,Default,,0,0,0,,Kita bahkan tidak berpacaran!
Dialogue: 0,0:09:19.46,0:09:21.32,Default,,0,0,0,,Peranmu adalah wanita yang,
Dialogue: 0,0:09:21.32,0:09:25.89,Default,,0,0,0,,meski saling mencintai,\Ndiselingkuhi karena masalah sepele,
Dialogue: 0,0:09:25.89,0:09:29.38,Default,,0,0,0,,tapi tetap memilih\Nuntuk memaafkan kekasihnya. Benar?
Dialogue: 0,0:09:29.38,0:09:30.14,Default,,0,0,0,,Ya.
Dialogue: 0,0:09:30.14,0:09:31.71,Default,,0,0,0,,Bagaimana perasaanmu sebenarnya\Ntentang itu?
Dialogue: 0,0:09:31.71,0:09:35.88,Default,,0,0,0,,Bayangkan adegan saat pria itu\Nmenyatakan cinta sekali lagi.
Dialogue: 0,0:09:36.16,0:09:38.82,Default,,0,0,0,,Bisakah kau secara pribadi mengatakan\Nkau mencintainya seperti di naskah?
Dialogue: 0,0:09:39.59,0:09:40.99,Default,,0,0,0,,Kau pasti bertanya-tanya.
Dialogue: 0,0:09:40.99,0:09:41.76,Default,,0,0,0,,Ya...
Dialogue: 0,0:09:41.76,0:09:45.47,Default,,0,0,0,,Itu sebabnya pilihan terbaikmu\Nadalah menjalaninya.
Dialogue: 0,0:09:45.47,0:09:48.93,Default,,0,0,0,,Dorongan apa pun yang menyerangmu\Nadalah jawabanmu.
Dialogue: 0,0:09:49.30,0:09:53.22,Default,,0,0,0,,Maksudmu, kita harus menjalin\Nhubungan palsu lagi,
Dialogue: 0,0:09:53.47,0:09:56.89,Default,,0,0,0,,tapi kali ini aku diselingkuhi?
Dialogue: 0,0:09:57.22,0:09:59.32,Default,,0,0,0,,Dengan siapa kau selingkuh?
Dialogue: 0,0:10:00.10,0:10:01.17,Default,,0,0,0,,Itu aku.
Dialogue: 0,0:10:01.17,0:10:01.70,Default,,0,0,0,,Apa...
Dialogue: 0,0:10:01.70,0:10:02.90,Default,,0,0,0,,Kenapa kau, Iko?!
Dialogue: 0,0:10:02.90,0:10:05.78,Default,,0,0,0,,Karena aku mencintai Bukki.
Dialogue: 0,0:10:05.78,0:10:06.78,Default,,0,0,0,,Kau apa?!
Dialogue: 0,0:10:06.78,0:10:08.78,Default,,0,0,0,,Begitulah ceritanya.
Dialogue: 0,0:10:08.78,0:10:11.91,Default,,0,0,0,,Jangan menganggapnya sebagai kebenaran.\NDia yang paling siap.
Dialogue: 0,0:10:11.91,0:10:15.94,Default,,0,0,0,,Saling mencintai denganmu,\Ntapi kau malah selingkuh dengan Iko.
Dialogue: 0,0:10:15.94,0:10:19.00,Default,,0,0,0,,Tidak ada yang realistis mengenai ini.\NAku tidak mengerti maksudnya!
Dialogue: 0,0:10:19.27,0:10:23.67,Default,,0,0,0,,Apakah kau lebih suka diam saja\Nsetelah Oizumi mengkritikmu?
Dialogue: 0,0:10:24.62,0:10:26.68,Default,,0,0,0,,Dia pasti mengejekmu.
Dialogue: 0,0:10:26.68,0:10:28.46,Default,,0,0,0,,Kau hanya memiliki suara yang cantik,
Dialogue: 0,0:10:28.46,0:10:34.07,Default,,0,0,0,,dan pengisi suara yang tak bisa berakting\Ndi depan kamera hanyalah aktor kelas tiga.
Dialogue: 0,0:10:35.10,0:10:36.55,Default,,0,0,0,,Apakah kau tidak ingin membalasnya?
Dialogue: 0,0:10:36.55,0:10:38.84,Default,,0,0,0,,Apakah kau tidak ingin\Nmenikmati kekalahannya?
Dialogue: 0,0:10:41.08,0:10:43.18,Default,,0,0,0,,Aku {\i1}sangat{\i0} ingin membalasnya!
Dialogue: 0,0:10:43.18,0:10:44.64,Default,,0,0,0,,Bagus! Itu baru semangatnya!
Dialogue: 0,0:10:44.64,0:10:45.89,Default,,0,0,0,,Aku akan menunjukkan siapa bosnya!
Dialogue: 0,0:10:45.89,0:10:47.85,Default,,0,0,0,,Bagus sekali! Kau penuh dengan emosi!
Dialogue: 0,0:10:47.85,0:10:49.88,Default,,0,0,0,,Dia akan merangkak dan menjilat sepatuku!
Dialogue: 0,0:10:49.88,0:10:51.73,Default,,0,0,0,,Aku tidak yakin tentang yang itu, Ketua.
Dialogue: 0,0:10:51.73,0:10:53.40,Default,,0,0,0,,Bagaimanapun, kita harus mulai berlatih.
Dialogue: 0,0:10:53.40,0:10:56.15,Default,,0,0,0,,Di mana saja boleh.
Dialogue: 0,0:10:59.10,0:10:59.78,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:11:00.08,0:11:01.76,Default,,0,0,0,,Bukan apa-apa, hanya...
Dialogue: 0,0:11:02.50,0:11:03.66,Default,,0,0,0,,Aku minta maaf.
Dialogue: 0,0:11:04.16,0:11:08.59,Default,,0,0,0,,Aku selalu...\Nagak menyusahkan untuk dihadapi.
Dialogue: 0,0:11:08.59,0:11:09.88,Default,,0,0,0,,Aku tidak keberatan dengan itu.
Dialogue: 0,0:11:10.25,0:11:12.79,Default,,0,0,0,,Itu yang menjadikanmu menawan.
Dialogue: 0,0:11:22.28,0:11:23.90,Default,,0,0,0,,Apa-apaan?
Dialogue: 0,0:11:23.90,0:11:24.84,Default,,0,0,0,,Pergi.
Dialogue: 0,0:11:27.09,0:11:28.04,Default,,0,0,0,,"SMA Furin"
Dialogue: 0,0:11:28.04,0:11:29.35,Default,,0,0,0,,Seperti yang aku katakan.
Dialogue: 0,0:11:29.70,0:11:33.26,Default,,0,0,0,,Aku diam-diam menemui Ki... Iko.
Dialogue: 0,0:11:33.26,0:11:35.77,Default,,0,0,0,,Tapi kau adalah\Nsatu-satunya wanita bagiku.
Dialogue: 0,0:11:35.77,0:11:39.09,Default,,0,0,0,,Kumohon, bisakah kita\Nmulai dari awal lagi?
Dialogue: 0,0:11:42.77,0:11:43.98,Default,,0,0,0,,Toiletnya ada di sana.
Dialogue: 0,0:11:43.98,0:11:46.07,Default,,0,0,0,,Ya, aku sudah tahu\Nkau akan mengatakan itu!
Dialogue: 0,0:11:46.36,0:11:49.44,Default,,0,0,0,,Maaf, tapi semua ini tidak terasa nyata.
Dialogue: 0,0:11:49.44,0:11:52.41,Default,,0,0,0,,Aku tidak bisa seumur hidupku\Nmembayangkan kalian berdua berkencan.
Dialogue: 0,0:11:52.41,0:11:54.36,Default,,0,0,0,,Aku mencintaimu, Sayang.
Dialogue: 0,0:11:54.36,0:11:56.32,Default,,0,0,0,,Sampai maut memisahkan kita.
Dialogue: 0,0:11:56.73,0:11:58.16,Default,,0,0,0,,Memalukan sekali.
Dialogue: 0,0:11:58.16,0:12:00.49,Default,,0,0,0,,Memang sulit untuk bisa langsung\Nmelakukannya dengan benar.
Dialogue: 0,0:12:00.49,0:12:01.90,Default,,0,0,0,,Kita harus melakukan ini\Nlangkah demi langkah.
Dialogue: 0,0:12:01.90,0:12:03.22,Default,,0,0,0,,Apakah kita sudah selesai hari ini?
Dialogue: 0,0:12:03.22,0:12:06.56,Default,,0,0,0,,Ya. Aku dan Iko punya tugas\Nyang harus diselesaikan.
Dialogue: 0,0:12:08.82,0:12:11.41,Default,,0,0,0,,{\i1}Aku merasa\Nrencana ini tidak akan berhasil.{\i0}
Dialogue: 0,0:12:11.71,0:12:16.68,Default,,0,0,0,,{\i1}Iko berkencan dengan pria itu rasanya\Nsangat jauh dari kenyataan...{\i0}
Dialogue: 0,0:12:18.71,0:12:20.85,Default,,0,0,0,,{\i1}Baiklah, kemungkinannya\Ntidak sepenuhnya nol.{\i0}
Dialogue: 0,0:12:22.35,0:12:25.52,Default,,0,0,0,,{\i1}Sepertinya aku agak penasaran\Nseperti apa rasanya{\i0}
Dialogue: 0,0:12:25.81,0:12:28.73,Default,,0,0,0,,{\i1}saat orang yang dicintai\Ndirebut dari kita.{\i0}
Dialogue: 0,0:12:34.65,0:12:35.78,Default,,0,0,0,,Hei, Arisu.
Dialogue: 0,0:12:35.78,0:12:39.49,Default,,0,0,0,,Berapa lama kau berencana\Nmerahasiakan hubungan kita?
Dialogue: 0,0:12:39.49,0:12:40.93,Default,,0,0,0,,Kita tidak punya pilihan.
Dialogue: 0,0:12:40.93,0:12:44.61,Default,,0,0,0,,Akan ada bayaran yang sangat besar\Njika mereka tahu kita berkencan.
Dialogue: 0,0:12:44.61,0:12:49.44,Default,,0,0,0,,Aku mau memilikimu untuk diriku sendiri,\Ntapi aku tidak adil jika begitu, 'kan?
Dialogue: 0,0:12:49.44,0:12:53.63,Default,,0,0,0,,Tidakkah menurutmu seru\Njika kita terus berpura-pura?
Dialogue: 0,0:12:55.11,0:12:57.11,Default,,0,0,0,,Kurasa kau benar.
Dialogue: 0,0:12:57.11,0:12:59.64,Default,,0,0,0,,{\i1}Mereka berdua? Tunggu, serius?{\i0}
Dialogue: 0,0:12:59.64,0:13:03.05,Default,,0,0,0,,{\i1}Mustahil! Mustahil! Tidak mungkin!{\i0}
Dialogue: 0,0:13:03.35,0:13:06.16,Default,,0,0,0,,Ya ampun, kau harus melihat ekspresinya.
Dialogue: 0,0:13:06.16,0:13:09.33,Default,,0,0,0,,Berhenti! Jangan melihatnya!\NDia bisa tahu!
Dialogue: 0,0:13:09.33,0:13:12.98,Default,,0,0,0,,Apakah kau yakin ini akan berhasil?
Dialogue: 0,0:13:12.98,0:13:15.93,Default,,0,0,0,,Jangan khawatir. Shinobu dan Rikka bilang\Nini akan berhasil.
Dialogue: 0,0:13:16.59,0:13:18.06,Default,,0,0,0,,Aha.
Dialogue: 0,0:13:18.35,0:13:21.31,Default,,0,0,0,,Kau ingin\NNene–chan mengalami diselingkuhi.
Dialogue: 0,0:13:21.31,0:13:22.02,Default,,0,0,0,,Itu mudah.
Dialogue: 0,0:13:22.50,0:13:24.81,Default,,0,0,0,,Kalau begitu,\Ncarilah pacar untuk dirimu sendiri.
Dialogue: 0,0:13:24.81,0:13:26.40,Default,,0,0,0,,Kau membuatnya terdengar sangat mudah.
Dialogue: 0,0:13:26.75,0:13:28.24,Default,,0,0,0,,Tentu saja hanya untuk berpura-pura.
Dialogue: 0,0:13:28.58,0:13:34.08,Default,,0,0,0,,Melihat dia menyaksikan kencan rahasiamu\Nakan sangat mengejutkan.
Dialogue: 0,0:13:34.54,0:13:35.45,Default,,0,0,0,,Tunggu sebentar.
Dialogue: 0,0:13:35.79,0:13:39.12,Default,,0,0,0,,Dia tidak harus menyukaiku,\Ntapi tidakkah rencana ini
Dialogue: 0,0:13:39.12,0:13:42.21,Default,,0,0,0,,bergantung pada asumsi\Nbahwa perasaannya padaku positif?
Dialogue: 0,0:13:42.71,0:13:45.38,Default,,0,0,0,,Berhenti bertingkah sok, Bodoh!
Dialogue: 0,0:13:45.38,0:13:46.96,Default,,0,0,0,,Aku {\i1}benci{\i0} kau!
Dialogue: 0,0:13:47.52,0:13:49.88,Default,,0,0,0,,Kami juga pernah mengalami momen canggung.
Dialogue: 0,0:13:49.88,0:13:53.22,Default,,0,0,0,,Menurutku, dia cukup menyukaimu.
Dialogue: 0,0:13:53.71,0:13:57.04,Default,,0,0,0,,Kau pasti sudah diusir dari klub\Njika dia benar-benar membencimu.
Dialogue: 0,0:13:57.95,0:13:59.78,Default,,0,0,0,,Apakah begitu?
Dialogue: 0,0:13:59.78,0:14:02.06,Default,,0,0,0,,Jadi, siapa yang akan menjadi pacarnya?
Dialogue: 0,0:14:02.33,0:14:04.08,Default,,0,0,0,,Ingin menentukan ini\Ndengan batu–kertas–gunting?
Dialogue: 0,0:14:04.71,0:14:06.18,Default,,0,0,0,,Batu, kertas,
Dialogue: 0,0:14:06.18,0:14:07.00,Default,,0,0,0,,gunting!
Dialogue: 0,0:14:07.49,0:14:10.39,Default,,0,0,0,,Ini berhasil, tapi...
Dialogue: 0,0:14:11.78,0:14:15.32,Default,,0,0,0,,Nene–chan menanggapi ini lebih serius\Ndaripada yang kita duga, bukan?
Dialogue: 0,0:14:15.58,0:14:17.78,Default,,0,0,0,,Dia benar-benar mematung.
Dialogue: 0,0:14:18.12,0:14:19.74,Default,,0,0,0,,Ini tidak seburuk diselingkuhi,
Dialogue: 0,0:14:19.74,0:14:22.57,Default,,0,0,0,,tapi kupikir dia terkejut
Dialogue: 0,0:14:22.57,0:14:25.74,Default,,0,0,0,,melihat pria yang dekat dengannya\Nberkencan dengan temannya.
Dialogue: 0,0:14:26.01,0:14:27.83,Default,,0,0,0,,Kelihatannya lebih dari itu...
Dialogue: 0,0:14:27.83,0:14:31.41,Default,,0,0,0,,Bagus, sekarang ada tiga patung.
Dialogue: 0,0:14:31.41,0:14:35.75,Default,,0,0,0,,Nene–chan seharusnya turun tangan\Nsesuai rencana.
Dialogue: 0,0:14:35.75,0:14:37.88,Default,,0,0,0,,Kurasa mereka tidak yakin\Napa yang harus dilakukan selanjutnya?
Dialogue: 0,0:14:38.13,0:14:41.17,Default,,0,0,0,,{\i1}Sial. Tidak ada lagi\Nyang bisa kami lakukan...{\i0}
Dialogue: 0,0:14:41.47,0:14:43.84,Default,,0,0,0,,{\i1}Himekawa masih mematung.{\i0}
Dialogue: 0,0:14:44.10,0:14:46.50,Default,,0,0,0,,{\i1}Mungkin kami harus memulai dari awal...{\i0}
Dialogue: 0,0:14:47.81,0:14:48.79,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:14:50.10,0:14:52.72,Default,,0,0,0,,Apakah kau pernah mencium seseorang?
Dialogue: 0,0:14:54.39,0:14:56.13,Default,,0,0,0,,Ya, pernah.
Dialogue: 0,0:14:56.13,0:14:57.33,Default,,0,0,0,,Apa?! Benarkah?!
Dialogue: 0,0:14:57.33,0:14:59.11,Default,,0,0,0,,Kapan itu?! Mencium siapa?!
Dialogue: 0,0:14:59.11,0:15:01.43,Default,,0,0,0,,Baru-baru ini...
Dialogue: 0,0:15:02.97,0:15:05.98,Default,,0,0,0,,{\i1}Bagaimana perasaanmu terhadap Bukki, Nene?{\i0}
Dialogue: 0,0:15:06.34,0:15:07.75,Default,,0,0,0,,{\i1}Tidak banyak.{\i0}
Dialogue: 0,0:15:07.75,0:15:10.49,Default,,0,0,0,,{\i1}Aku masih membenci laki-laki.{\i0}
Dialogue: 0,0:15:10.49,0:15:13.17,Default,,0,0,0,,{\i1}Tapi... itu...{\i0}
Dialogue: 0,0:15:13.17,0:15:16.52,Default,,0,0,0,,{\i1}Kurasa dia lebih baik\Ndaripada pria lain yang aku kenal.{\i0}
Dialogue: 0,0:15:19.08,0:15:24.51,Default,,0,0,0,,Saat itu, Nene masih tidak jelas soal itu,\Ntapi kurasa aku akan berterus terang.
Dialogue: 0,0:15:24.51,0:15:25.23,Default,,0,0,0,,Hah?
Dialogue: 0,0:15:29.59,0:15:32.34,Default,,0,0,0,,Aku ingin menciummu.
Dialogue: 0,0:15:35.47,0:15:36.55,Default,,0,0,0,,Aku mencintaimu.
Dialogue: 0,0:15:37.21,0:15:37.97,Default,,0,0,0,,Arisu.
Dialogue: 0,0:15:37.97,0:15:40.97,Default,,0,0,0,,"Sentimentalitas Berasal\NDari Meningkatnya Kasih Sayang"
Dialogue: 0,0:15:41.82,0:15:43.97,Default,,0,0,0,,Aku ingin menciummu.
Dialogue: 0,0:15:46.04,0:15:47.02,Default,,0,0,0,,Aku mencintaimu.
Dialogue: 0,0:15:47.37,0:15:48.43,Default,,0,0,0,,Arisu.
Dialogue: 0,0:15:50.40,0:15:52.94,Default,,0,0,0,,{\i1}Aku mengerti.\NPenilaian yang masuk akal, Kirino.{\i0}
Dialogue: 0,0:15:53.33,0:15:56.10,Default,,0,0,0,,{\i1}Berciuman memang merupakan\Ntindakan sepasang kekasih.{\i0}
Dialogue: 0,0:15:56.10,0:15:58.10,Default,,0,0,0,,{\i1}Ini menambah realisme\Npada kepura-puraan kita.{\i0}
Dialogue: 0,0:15:58.10,0:16:00.74,Default,,0,0,0,,{\i1}Ini pasti akan memaksa Himekawa\Nuntuk menghentikan kami.{\i0}
Dialogue: 0,0:16:01.04,0:16:06.74,Default,,0,0,0,,{\i1}Namun, aku masih ragu\Nini akan membuatnya cemburu.{\i0}
Dialogue: 0,0:16:07.20,0:16:10.35,Default,,0,0,0,,{\i1}Tetap saja, aku ahli\Ndalam berpura-pura berciuman.{\i0}
Dialogue: 0,0:16:10.35,0:16:14.25,Default,,0,0,0,,{\i1}Karena aku selalu berperan\Nsebagai pangeran dalam drama di TK.{\i0}
Dialogue: 0,0:16:15.13,0:16:17.45,Default,,0,0,0,,{\i1}Dia cukup dekat, ya?{\i0}
Dialogue: 0,0:16:17.45,0:16:19.90,Default,,0,0,0,,{\i1}Apakah dia berniat untuk berhenti\Nbeberapa inci saja?!{\i0}
Dialogue: 0,0:16:19.90,0:16:21.78,Default,,0,0,0,,{\i1}Tentu saja dia tidak benar-benar akan...{\i0}
Dialogue: 0,0:16:21.78,0:16:24.72,Default,,0,0,0,,{\i1}Apakah dia sudah sadar akan panggilannya\Nsebagai aktris atau semacamnya?!{\i0}
Dialogue: 0,0:16:27.36,0:16:28.85,Default,,0,0,0,,{\i1}Berhenti, Kirino!{\i0}
Dialogue: 0,0:16:29.22,0:16:30.75,Default,,0,0,0,,{\i1}Apakah kau bersungguh-sungguh?{\i0}
Dialogue: 0,0:16:35.10,0:16:37.27,Default,,0,0,0,,Berhenti!
Dialogue: 0,0:16:37.27,0:16:39.84,Default,,0,0,0,,A–Apa yang kalian berdua pikirkan?!
Dialogue: 0,0:16:39.84,0:16:41.19,Default,,0,0,0,,Kita sedang berada di {\i1}sekolah!{\i0}
Dialogue: 0,0:16:41.19,0:16:44.11,Default,,0,0,0,,Bukan berarti kalian harus melakukannya\Nmeskipun tidak di sekolah!
Dialogue: 0,0:16:44.38,0:16:47.36,Default,,0,0,0,,Tidak pernah ada waktu, tempat,\Natau kesempatan untuk ini!
Dialogue: 0,0:16:47.36,0:16:49.04,Default,,0,0,0,,Nene–chan, santai saja!
Dialogue: 0,0:16:49.04,0:16:51.28,Default,,0,0,0,,Maaf. Itu semua hanyalah akting.
Dialogue: 0,0:16:51.28,0:16:53.40,Default,,0,0,0,,Izinkan kami menjelaskan semuanya.
Dialogue: 0,0:16:55.34,0:16:56.74,Default,,0,0,0,,Begitulah.
Dialogue: 0,0:16:57.10,0:16:58.87,Default,,0,0,0,,Maaf karena sudah menipumu.
Dialogue: 0,0:16:59.24,0:17:01.78,Default,,0,0,0,,Kami harus melakukannya\Nagar ini tampak nyata.
Dialogue: 0,0:17:01.78,0:17:03.78,Default,,0,0,0,,Aku tidak marah. Mengerti?
Dialogue: 0,0:17:03.78,0:17:06.75,Default,,0,0,0,,Bagaimana? Apakah ini membantu aktingmu?
Dialogue: 0,0:17:08.30,0:17:09.57,Default,,0,0,0,,Entahlah!
Dialogue: 0,0:17:12.46,0:17:14.54,Default,,0,0,0,,Ah, sial. Apakah kita membuatnya kesal?
Dialogue: 0,0:17:14.54,0:17:16.98,Default,,0,0,0,,Tidak apa-apa. Menurutku...
Dialogue: 0,0:17:18.01,0:17:20.18,Default,,0,0,0,,Sebaiknya kita tetap bersamanya\Nuntuk berjaga-jaga.
Dialogue: 0,0:17:20.18,0:17:21.77,Default,,0,0,0,,Nene–chan!
Dialogue: 0,0:17:21.77,0:17:24.14,Default,,0,0,0,,Salahkan Shinobu. Dia mengatur segalanya.
Dialogue: 0,0:17:24.14,0:17:26.29,Default,,0,0,0,,Rikka–chan, apa?!
Dialogue: 0,0:17:26.94,0:17:29.06,Default,,0,0,0,,Keputusan bagus, Kirino.
Dialogue: 0,0:17:29.50,0:17:31.73,Default,,0,0,0,,Aku bingung harus berbuat apa.
Dialogue: 0,0:17:31.73,0:17:34.48,Default,,0,0,0,,Aku tidak kepikiran\Nuntuk berpura-pura berciuman.
Dialogue: 0,0:17:34.48,0:17:36.53,Default,,0,0,0,,Itu menambah realisme\Npada akting sebagai kekasih.
Dialogue: 0,0:17:37.60,0:17:40.49,Default,,0,0,0,,Benar, 'kan? Keterampilan improvisasiku\Nmenyelamatkan kita.
Dialogue: 0,0:17:41.98,0:17:46.40,Default,,0,0,0,,Harus kuakui aku sempat panik saat mengira\Nkau akan benar-benar menciumku.
Dialogue: 0,0:17:47.81,0:17:48.66,Default,,0,0,0,,Jadi...
Dialogue: 0,0:17:49.07,0:17:52.08,Default,,0,0,0,,Bukki, apakah kau dan Nene\Npernah berciuman?
Dialogue: 0,0:17:52.08,0:17:53.17,Default,,0,0,0,,Apa yang kau bicarakan?
Dialogue: 0,0:17:53.17,0:17:54.73,Default,,0,0,0,,Tentu saja tidak pernah.
Dialogue: 0,0:17:55.42,0:17:56.29,Default,,0,0,0,,Ini.
Dialogue: 0,0:17:56.29,0:17:57.92,Default,,0,0,0,,Tanda penghargaan sederhana.
Dialogue: 0,0:17:57.92,0:17:59.30,Default,,0,0,0,,Tidak pernah?
Dialogue: 0,0:17:59.58,0:18:01.49,Default,,0,0,0,,Apakah Himekawa menyatakan sebaliknya?
Dialogue: 0,0:18:01.49,0:18:02.54,Default,,0,0,0,,Tidak.
Dialogue: 0,0:18:02.54,0:18:04.63,Default,,0,0,0,,Kalau begitu, kenapa bertanya kepadaku?
Dialogue: 0,0:18:08.02,0:18:09.22,Default,,0,0,0,,Hei.
Dialogue: 0,0:18:09.22,0:18:10.78,Default,,0,0,0,,Aku lebih suka punyamu.
Dialogue: 0,0:18:10.78,0:18:12.78,Default,,0,0,0,,Apakah kau yakin?\NAku baru saja meminumnya.
Dialogue: 0,0:18:12.78,0:18:13.64,Default,,0,0,0,,Tidak apa-apa.
Dialogue: 0,0:18:13.64,0:18:15.64,Default,,0,0,0,,Jika kau tidak keberatan.
Dialogue: 0,0:18:18.73,0:18:21.21,Default,,0,0,0,,Aku akan menerima ini untuk saat ini.
Dialogue: 0,0:18:23.10,0:18:25.01,Default,,0,0,0,,ini {\i1}pahit!{\i0}
Dialogue: 0,0:18:25.01,0:18:27.11,Default,,0,0,0,,Kau tidak minum kopi, 'kan?
Dialogue: 0,0:18:31.49,0:18:32.82,Default,,0,0,0,,"Klub Teater"\NAhh!
Dialogue: 0,0:18:32.82,0:18:35.91,Default,,0,0,0,,Maaf atas perbuatanku yang menyedihkan!
Dialogue: 0,0:18:36.30,0:18:40.38,Default,,0,0,0,,Aku memang bodoh karena aku dungu.
Dialogue: 0,0:18:40.38,0:18:45.31,Default,,0,0,0,,Baru sekarang aku mengerti\Nbetapa berartinya dirimu bagiku.
Dialogue: 0,0:18:45.31,0:18:46.16,Default,,0,0,0,,Ahhh!
Dialogue: 0,0:18:46.16,0:18:49.34,Default,,0,0,0,,Bahwa mawar luar biasa\Nyang bisa kukembangkan dengan bangga,
Dialogue: 0,0:18:49.66,0:18:53.90,Default,,0,0,0,,itu semua karena pancaran sinarmu,\Nsayangku, matahariku!
Dialogue: 0,0:18:54.30,0:18:56.70,Default,,0,0,0,,Apakah hanya perasaanku,\Natau dia benar-benar banyak berkorban?
Dialogue: 0,0:18:56.70,0:18:59.76,Default,,0,0,0,,Aku terkesan Himekawa–san memilih\Nuntuk membantu kita lagi.
Dialogue: 0,0:18:59.76,0:19:02.26,Default,,0,0,0,,Kembali setelah dikritik seperti itu\Nbutuh nyali.
Dialogue: 0,0:19:02.26,0:19:03.18,Default,,0,0,0,,Kumohon!
Dialogue: 0,0:19:03.18,0:19:05.56,Default,,0,0,0,,Jika kau mau memaafkanku,
Dialogue: 0,0:19:05.56,0:19:08.56,Default,,0,0,0,,api cinta masih menyala!
Dialogue: 0,0:19:08.95,0:19:12.63,Default,,0,0,0,,Bisakah kau mengatakan\Nbahwa kau mencintaiku sekali lagi?!
Dialogue: 0,0:19:25.28,0:19:29.16,Default,,0,0,0,,Aku tidak ingin\Nmelihat wajahmu lagi. Pergi.
Dialogue: 0,0:19:31.91,0:19:33.42,Default,,0,0,0,,Berhenti! Berhenti!
Dialogue: 0,0:19:33.69,0:19:35.71,Default,,0,0,0,,Himekawa–san, itu tidak ada dalam naskah!
Dialogue: 0,0:19:35.71,0:19:36.90,Default,,0,0,0,,Itu sangat menakutkan.
Dialogue: 0,0:19:36.90,0:19:40.62,Default,,0,0,0,,Seharusnya kau memaafkan tokoh protagonis\Ndan mengatakan kau mencintainya.
Dialogue: 0,0:19:40.62,0:19:42.46,Default,,0,0,0,,Tidak, ini bagus.
Dialogue: 0,0:19:42.46,0:19:43.88,Default,,0,0,0,,Oizumi–san?!
Dialogue: 0,0:19:45.63,0:19:49.12,Default,,0,0,0,,Ekspresi dan penyampaianmu barusan\Nsungguh luar biasa!
Dialogue: 0,0:19:49.12,0:19:52.88,Default,,0,0,0,,Itu memiliki realisme seorang wanita\Nyang merasa terhina karena perselingkuhan.
Dialogue: 0,0:19:52.88,0:19:56.98,Default,,0,0,0,,Kau membiarkan emosi aslimu dirasakan.
Dialogue: 0,0:19:56.98,0:19:59.15,Default,,0,0,0,,Apakah itu akting berdasarkan pengalaman?
Dialogue: 0,0:20:01.14,0:20:02.96,Default,,0,0,0,,Semacam itu?
Dialogue: 0,0:20:02.96,0:20:04.36,Default,,0,0,0,,Tunggu, serius?!
Dialogue: 0,0:20:04.64,0:20:07.06,Default,,0,0,0,,Kau harus menceritakan\Nlebih banyak kepadaku!
Dialogue: 0,0:20:07.06,0:20:09.64,Default,,0,0,0,,Apa yang perlu diceritakan?
Dialogue: 0,0:20:12.82,0:20:14.37,Default,,0,0,0,,Aku sudah membalas dendam.
Dialogue: 0,0:20:14.37,0:20:15.30,Default,,0,0,0,,Pujilah aku.
Dialogue: 0,0:20:15.30,0:20:16.64,Default,,0,0,0,,Aku melihatnya.
Dialogue: 0,0:20:16.64,0:20:18.07,Default,,0,0,0,,Kau luar biasa.
Dialogue: 0,0:20:18.07,0:20:21.41,Default,,0,0,0,,Itu agak terlalu jujur.
Dialogue: 0,0:20:21.41,0:20:23.78,Default,,0,0,0,,Kelihatannya kau berhubungan baik\Ndengan anggota teater.
Dialogue: 0,0:20:23.78,0:20:24.63,Default,,0,0,0,,Ya.
Dialogue: 0,0:20:24.63,0:20:30.38,Default,,0,0,0,,Aku berusaha tidak menyembunyikan perasaan\Ndan mengutarakan pikiranku.
Dialogue: 0,0:20:30.38,0:20:31.92,Default,,0,0,0,,Itu luar biasa.
Dialogue: 0,0:20:35.44,0:20:37.01,Default,,0,0,0,,Aku mungkin harus berterima kasih\Nkepadamu untuk itu.
Dialogue: 0,0:20:37.55,0:20:39.01,Default,,0,0,0,,Terima kasih.
Dialogue: 0,0:20:39.46,0:20:43.10,Default,,0,0,0,,Rasanya aku mengerti apa yang dimaksud\Ndengan "emosi berasal dari impuls".
Dialogue: 0,0:20:43.10,0:20:46.91,Default,,0,0,0,,Perasaan itu tidak bisa aku tahan.
Dialogue: 0,0:20:46.91,0:20:49.20,Default,,0,0,0,,Aku harap aku bisa menerapkannya\Ndalam aktingku.
Dialogue: 0,0:20:50.89,0:20:52.61,Default,,0,0,0,,Kau sudah ada kemajuan.
Dialogue: 0,0:20:52.91,0:20:55.02,Default,,0,0,0,,Pertunjukan kecil bersama Iko itu\Nterbayar lunas.
Dialogue: 0,0:20:55.02,0:20:55.82,Default,,0,0,0,,Namun, harus kukatakan,
Dialogue: 0,0:20:55.82,0:20:57.94,Default,,0,0,0,,"Dilarang Masuk"\Nciuman itu berlebihan.
Dialogue: 0,0:20:57.94,0:20:58.99,Default,,0,0,0,,Dengar dulu.
Dialogue: 0,0:20:58.99,0:21:01.54,Default,,0,0,0,,Itu adalah improvisasi dari Kirino.
Dialogue: 0,0:21:01.54,0:21:05.17,Default,,0,0,0,,Kami berasumsi\Nkau akan menyela lebih cepat.
Dialogue: 0,0:21:07.22,0:21:11.69,Default,,0,0,0,,Maksudmu, kalian akan meneruskannya\Njika aku tidak menghentikan kalian?
Dialogue: 0,0:21:13.56,0:21:17.74,Default,,0,0,0,,Pertama Kirino, sekarang kau.\NGadis seusia kalian menyukai topik ini.
Dialogue: 0,0:21:17.74,0:21:20.52,Default,,0,0,0,,Tentu saja tidak. Itu hanya akting.
Dialogue: 0,0:21:30.47,0:21:32.50,Default,,0,0,0,,Iko mungkin bersungguh-sungguh.
Dialogue: 0,0:21:32.50,0:21:34.31,Default,,0,0,0,,Aku sangat meragukannya.
Dialogue: 0,0:21:35.40,0:21:37.19,Default,,0,0,0,,Jika itu aku,
Dialogue: 0,0:21:37.19,0:21:40.02,Default,,0,0,0,,aku mungkin\Ntidak akan menghentikan ciumannya.
Dialogue: 0,0:21:40.02,0:21:40.67,Default,,0,0,0,,Hah?
Dialogue: 0,0:21:42.06,0:21:43.82,Default,,0,0,0,,B–Bukan apa-apa!
Dialogue: 0,0:21:43.82,0:21:44.86,Default,,0,0,0,,Aku akan pulang!
Dialogue: 0,0:21:44.86,0:21:45.36,Default,,0,0,0,,Hei!
Dialogue: 0,0:21:45.36,0:21:46.99,Default,,0,0,0,,Ini semua salahmu!
Dialogue: 0,0:21:46.99,0:21:50.01,Default,,0,0,0,,Sekarang aku tidak bisa tidak mengatakan\Napa yang ada dalam pikiranku!
Dialogue: 0,0:21:50.01,0:21:52.04,Default,,0,0,0,,Bagaimana itu jadi salahku–
Dialogue: 0,0:21:56.17,0:21:57.20,Default,,0,0,0,,Astaga!
Dialogue: 0,0:21:57.60,0:21:59.58,Default,,0,0,0,,Aku terasa impulsif, bukan?
Dialogue: 0,0:22:00.11,0:22:02.46,Default,,0,0,0,,Aku perlu mendapatkan sedikit imbalan.
Dialogue: 0,0:22:02.46,0:22:05.29,Default,,0,0,0,,Menurutku, aku sudah\Nlebih pandai berakting sekarang.
Dialogue: 0,0:22:06.92,0:22:09.92,Default,,0,0,0,,"Pembalasan yang Berhasil"
